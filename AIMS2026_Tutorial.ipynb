        "\n",
        "for epoch in range(epochs):\n",
        "    # Training\n",
        "    model.train()\n",
        "    optimizer.zero_grad()\n",
        "    predictions = model(X_train_t)\n",
        "    loss = criterion(predictions, y_train_t)\n",
        "    loss.backward()\n",
        "\n",
