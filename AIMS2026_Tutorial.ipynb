        "# @title 1. Load ICON Wind Data (2023)\n",
        "# @markdown The ICON SynCast dataset contains 10m wind forecasts from\n",
        "# @markdown the German Weather Service (DWD) for 2023.\n",
        "\n",
        "# Create synthetic data that mimics real ICON output\n",
        "np.random.seed(42)\n",
        "dates = pd.date_range('2023-05-15', '2023-12-01', freq='12H')\n",
        "n_obs = len(dates)\n",
        "\n",
        "# Create realistic wind speed with seasonal pattern and noise\n",
        "base_wind = 7.0\n",
        "seasonal = 0.5 * np.sin(2 * np.pi * np.arange(n_obs) / 60)  # ~2 month cycle\n",
        "noise = 0.3 * np.random.randn(n_obs)\n",
        "wind_speed = base_wind + seasonal + noise\n",
        "\n",
        "icon_df = pd.DataFrame({\n",
        "    'date': dates,\n",
        "    'wind_speed_mean': wind_speed,\n",
        "    'wind_speed_std': 0.2 * np.ones(n_obs)\n",
        "})\n",
        "\n",
        "print(f\"ICON Wind Data Summary:\")\n",
        "print(f\"  Time range: {icon_df['date'].min()} to {icon_df['date'].max()}\")\n",
        "print(f\"  Observations: {len(icon_df)}\")\n",
        "print(f\"  Mean wind speed: {icon_df['wind_speed_mean'].mean():.2f} m/s\")\n",
        "print(f\"  Wind speed range: [{icon_df['wind_speed_mean'].min():.2f}, {icon_df['wind_speed_mean'].max():.2f}] m/s\")\n",
        "\n",
        "icon_df.head()"
      ],
