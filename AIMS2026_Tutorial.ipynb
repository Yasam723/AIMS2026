        "    df = wind_df.copy()\n",
        "\n",
        "    # Rolling statistics\n",
        "    df['wind_rolling_mean_3'] = df['wind_speed_ms'].rolling(3).mean()\n",
        "    df['wind_rolling_mean_6'] = df['wind_speed_ms'].rolling(6).mean()\n",
        "    df['wind_rolling_mean_12'] = df['wind_speed_ms'].rolling(12).mean()\n",
        "    df['wind_rolling_std_3'] = df['wind_speed_ms'].rolling(3).std()\n",
        "\n",
        "    # Rate of change\n",
        "    df['wind_diff_1'] = df['wind_speed_ms'].diff()\n",
        "    df['wind_diff_3'] = df['wind_speed_ms'].diff(3)\n",
        "    df['wind_diff_6'] = df['wind_speed_ms'].diff(6)\n",
        "\n",
        "    # Lagged values\n",
        "    for lag in [1, 3, 6, 12]:\n",
