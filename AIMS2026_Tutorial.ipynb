        "# ============================================================\n",
        "# STEP 9: FEATURE IMPORTANCE ANALYSIS\n",
        "# ============================================================\n",
        "\n",
        "print(\"\\n9. Feature importance analysis...\")\n",
        "\n",
        "# Simple permutation importance\n",
        "def permutation_importance(model, X_test, y_test, feature_names, n_repeats=5):\n",
        "    \"\"\"Calculate feature importance by permuting each feature\"\"\"\n",
        "    base_score = r2_score(y_test, predictions)\n",
        "    importances = []\n",
        "\n",
        "    for i, name in enumerate(feature_names):\n",
        "        scores = []\n",
        "        for _ in range(n_repeats):\n",
        "            X_perm = X_test.copy()\n",
        "            X_perm[:, :, i] = np.random.permutation(X_perm[:, :, i])\n",
        "            with torch.no_grad():\n",
        "                X_perm_t = torch.FloatTensor(X_perm).to(device)\n",
        "                pred_perm = model(X_perm_t).cpu().numpy().flatten()\n",
        "            score = r2_score(y_test, pred_perm)\n",
        "            scores.append(score)\n",
        "        importances.append(base_score - np.mean(scores))\n",
        "\n",
        "    return np.array(importances)\n",
        "\n",
        "# Get feature names\n",
        "feature_names = enhanced_df.drop('year', axis=1).columns.tolist()\n",
        "\n",
        "# Calculate importance (if enough data)\n",
