        "# @title 5. Uncertainty Quantification\n",
        "# @markdown Apply conformal prediction to generate prediction intervals.\n",
        "\n",
        "def conformal_prediction(model, X_calib, y_calib, X_test, alpha=0.1):\n",
        "    \"\"\"Generate conformal prediction intervals\"\"\"\n",
        "    model.eval()\n",
        "\n",
        "    with torch.no_grad():\n",
        "        X_calib_tensor = torch.FloatTensor(X_calib).to(device)\n",
        "        y_pred_calib = model(X_calib_tensor).cpu().numpy().flatten()\n",
        "\n",
        "    # Calculate residuals\n",
        "    residuals = np.abs(y_calib - y_pred_calib)\n",
        "\n",
        "    # Quantile threshold\n",
        "    q = np.quantile(residuals, 1 - alpha)\n",
        "\n",
        "    # Apply to test set\n",
        "    with torch.no_grad():\n",
        "        X_test_tensor = torch.FloatTensor(X_test).to(device)\n",
        "        y_pred_test = model(X_test_tensor).cpu().numpy().flatten()\n",
        "\n",
        "    lower_bounds = y_pred_test - q\n",
        "    upper_bounds = y_pred_test + q\n",
        "\n",
        "    return y_pred_test, lower_bounds, upper_bounds, q\n",
        "\n",
        "# Split calibration data\n",
        "n_calib = len(X_val) // 2\n",
        "X_calib = X_val_scaled[:n_calib]\n",
        "y_calib = y_val[:n_calib]\n",
        "X_test_uq = X_val_scaled[n_calib:]\n",
        "y_test_uq = y_val[n_calib:]\n",
        "\n",
        "# Apply conformal prediction\n",
        "predictions_uq, lower, upper, q = conformal_prediction(model, X_calib, y_calib, X_test_uq, alpha=0.1)\n",
        "\n",
        "# Calculate coverage\n",
        "coverage = np.mean((lower <= y_test_uq) & (y_test_uq <= upper))\n",
        "\n",
        "print(f\"📊 Conformal Prediction Results:\")\n",
        "print(f\"  Alpha: 0.1 (90% confidence intervals)\")\n",
        "print(f\"  Calibration residual quantile: {q:.3f} Sv\")\n",
        "print(f\"  Actual coverage: {coverage:.3f} (target: 0.90)\")\n",
        "print(f\"  Interval width: {(upper - lower).mean():.3f} Sv\")"
      ],
