        "# @title 3. Historical Wind Data (1900-2014)\n",
        "# @markdown NOAA 20th Century Reanalysis V3 provides historical context.\n",
        "\n",
        "# Create synthetic historical wind data\n",
        "years_hist = np.arange(1900, 2015)\n",
        "np.random.seed(42)\n",
        "\n",
        "# Realistic wind with trend and decadal variability\n",
        "base_wind_hist = 7.0\n",
        "trend = -0.005 * (years_hist - 1900) / 100\n",
        "decadal = 0.3 * np.sin(2 * np.pi * (years_hist - 1900) / 30)\n",
        "noise_hist = 0.4 * np.random.randn(len(years_hist))\n",
        "wind_hist = base_wind_hist + trend + decadal + noise_hist\n",
        "wind_hist = np.clip(wind_hist, 6, 8)\n",
        "\n",
        "historical_wind_df = pd.DataFrame({\n",
        "    'year': years_hist,\n",
        "    'wind_speed_ms': wind_hist\n",
        "})\n",
        "\n",
        "print(f\"Historical Wind Data (1900-2014):\")\n",
        "print(f\"  Mean: {historical_wind_df['wind_speed_ms'].mean():.2f} m/s\")\n",
        "print(f\"  Std: {historical_wind_df['wind_speed_ms'].std():.2f} m/s\")\n",
        "print(f\"  Trend: {trend[-1]:.4f} m/s/year\")\n",
        "\n",
        "# Compare with 2023\n",
        "icon_mean = icon_df['wind_speed_mean'].mean()\n",
        "hist_mean = historical_wind_df['wind_speed_ms'].mean()\n",
        "hist_std = historical_wind_df['wind_speed_ms'].std()\n",
        "z_score = (icon_mean - hist_mean) / hist_std\n",
        "\n",
        "print(f\"\\n📊 Comparison with ICON 2023:\")\n",
        "print(f\"  Historical mean: {hist_mean:.2f} ± {hist_std:.2f} m/s\")\n",
        "print(f\"  ICON 2023 mean: {icon_mean:.2f} m/s\")\n",
        "print(f\"  2023 is {z_score:.2f} standard deviations from historical mean\")"
      ],
