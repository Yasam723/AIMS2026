        "ax.set_title('Historical Wind (1900-2014)'); ax.legend(); ax.grid(True, alpha=0.3)\n",
        "\n",
        "# LSTM predictions\n",
        "ax = axes[1, 0]\n",
        "ax.scatter(y_test, predictions, alpha=0.5)\n",
        "ax.plot([y_test.min(), y_test.max()], [y_test.min(), y_test.max()], 'r--', label='Perfect')\n",
        "ax.set_xlabel('Actual AMOC (Sv)'); ax.set_ylabel('Predicted AMOC (Sv)')\n",
        "ax.set_title(f'LSTM Predictions (R²={r2:.3f})'); ax.legend(); ax.grid(True, alpha=0.3)\n",
        "\n",
        "# Time series with uncertainty\n",
        "ax = axes[1, 1]\n",
        "test_years = years[-len(y_test_uq):]\n",
        "n_show = min(50, len(test_years))\n",
        "ax.plot(test_years[:n_show], y_test_uq[:n_show], 'b-', label='Actual', alpha=0.7)\n",
        "ax.plot(test_years[:n_show], pred_uq[:n_show], 'r--', label='Predicted', alpha=0.7)\n",
        "ax.fill_between(test_years[:n_show], lower[:n_show], upper[:n_show], alpha=0.3, color='gray', label='90% CI')\n",
        "ax.set_xlabel('Year'); ax.set_ylabel('AMOC (Sv)')\n",
        "ax.set_title('AMOC Prediction with Uncertainty'); ax.legend(); ax.grid(True, alpha=0.3)\n",
        "\n",
        "plt.suptitle(f'AMOC-ENSO Analysis: Wind leads ENSO by {abs(optimal_lag)} days (r={max_corr:.3f}, p={p_value:.4f})',\n",
        "             fontsize=12, fontweight='bold')\n",
        "plt.tight_layout()\n",
