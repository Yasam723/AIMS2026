        "# @title 2. ENSO Teleconnection Analysis\n",
        "# @markdown Calculate the lagged correlation between North Atlantic wind and ENSO.\n",
        "\n",
        "# Create synthetic ENSO index (Nino3.4)\n",
        "np.random.seed(42)\n",
        "nino34 = 0.5 * np.sin(2 * np.pi * np.arange(len(icon_df)) / 90)  # ~3 month cycle\n",
        "nino34 = nino34 + 0.3 * np.random.randn(len(icon_df))\n",
        "nino34 = (nino34 - nino34.mean()) / nino34.std()\n",
        "\n",
        "def lagged_correlation(series1, series2, max_lag=30):\n",
        "    \"\"\"Calculate lagged correlation between two time series\"\"\"\n",
        "    lags = np.arange(-max_lag, max_lag + 1)\n",
        "    correlations = []\n",
        "\n",
        "    for lag in lags:\n",
        "        if lag < 0:\n",
        "            corr = np.corrcoef(series1[:lag], series2[-lag:])[0, 1]\n",
        "        elif lag > 0:\n",
        "            corr = np.corrcoef(series1[lag:], series2[:-lag])[0, 1]\n",
        "        else:\n",
        "            corr = np.corrcoef(series1, series2)[0, 1]\n",
        "        correlations.append(corr)\n",
        "\n",
        "    return lags, np.array(correlations)\n",
        "\n",
        "# Calculate teleconnection\n",
        "lags, corr_values = lagged_correlation(icon_df['wind_speed_mean'].values, nino34, max_lag=15)\n",
        "\n",
        "# Find maximum correlation\n",
        "max_idx = np.argmax(np.abs(corr_values))\n",
        "optimal_lag = lags[max_idx]\n",
        "max_corr = corr_values[max_idx]\n",
        "\n",
        "print(f\"\\n📊 Teleconnection Results:\")\n",
        "print(f\"  Maximum correlation: {max_corr:.3f}\")\n",
        "print(f\"  Optimal lag: {optimal_lag} days\")\n",
        "if optimal_lag < 0:\n",
        "    print(f\"  ✅ Wind leads ENSO by {abs(optimal_lag)} days\")\n",
        "else:\n",
        "    print(f\"  ✅ ENSO leads wind by {optimal_lag} days\")\n",
        "\n",
        "# Statistical significance\n",
        "n = len(icon_df)\n",
        "t_stat = max_corr * np.sqrt((n - 2) / (1 - max_corr**2))\n",
        "p_value = 2 * (1 - stats.t.cdf(abs(t_stat), n - 2))\n",
        "\n",
        "print(f\"\\n📈 Statistical Significance:\")\n",
        "print(f\"  p-value: {p_value:.6f}\")\n",
        "if p_value < 0.05:\n",
        "    print(f\"  ✅ Result is statistically significant (p < 0.05)\")\n",
        "else:\n",
        "    print(f\"  ❌ Result is not statistically significant\")"
      ],
