      "source": [
        "import xarray as xr\n",
        "import numpy as np\n",
        "import pandas as pd\n",
        "import matplotlib.pyplot as plt\n",
        "from pathlib import Path\n",
        "import re\n",
        "import warnings\n",
        "import urllib.request\n",
        "import bz2\n",
        "from datetime import datetime, timedelta\n",
        "warnings.filterwarnings('ignore')\n",
        "\n",
        "print(\"=\"*70)\n",
        "print(\"ORGANIZING ALB_RAD DATASET WITH TODAY'S DATA (FIXED)\")\n",
        "print(\"=\"*70)\n",
        "\n",
        "# ============================================================\n",
        "# FUNCTION: Download today's ALB_RAD data\n",
        "# ============================================================\n",
        "\n",
        "def download_todays_albedo(output_dir=\"./alb_rad_data\"):\n",
        "    \"\"\"Download ALB_RAD for today's forecast runs\"\"\"\n",
        "    output_path = Path(output_dir)\n",
        "    output_path.mkdir(parents=True, exist_ok=True)\n",
        "\n",
        "    today = datetime.now().replace(hour=0, minute=0, second=0, microsecond=0)\n",
        "    downloaded = []\n",
        "\n",
        "    print(f\"\\nDownloading data for: {today.strftime('%Y-%m-%d')}\")\n",
        "\n",
        "    for hour in [0, 6, 12, 18]:\n",
        "        test_date = today.replace(hour=hour)\n",
        "        init_hour = f\"{test_date.hour:02d}\"\n",
        "        date_str = test_date.strftime('%Y%m%d%H')\n",
        "\n",
        "        filename = f\"icon-eu_europe_regular-lat-lon_single-level_{date_str}_000_ALB_RAD.grib2.bz2\"\n",
        "        url = f\"https://opendata.dwd.de/weather/nwp/icon-eu/grib/{init_hour}/alb_rad/{filename}\"\n",
        "        output_file = output_path / filename\n",
        "\n",
        "        try:\n",
        "            urllib.request.urlretrieve(url, output_file)\n",
        "            # Decompress\n",
        "            decompressed_file = output_file.with_suffix('')\n",
        "            with bz2.open(output_file, 'rb') as source, open(decompressed_file, 'wb') as dest:\n",
        "                dest.write(source.read())\n",
        "            print(f\"  ✓ Downloaded: {test_date.strftime('%Y-%m-%d %H:00')}\")\n",
        "            downloaded.append(decompressed_file)\n",
        "        except:\n",
        "            print(f\"  ✗ Not available: {test_date.strftime('%Y-%m-%d %H:00')}\")\n",
        "\n",
        "    return downloaded\n",
        "\n",
        "# ============================================================\n",
        "# FUNCTION: Load and extract albedo\n",
        "# ============================================================\n",
        "\n",
        "def load_albedo_pygrib(file_path):\n",
        "    \"\"\"Load ALB_RAD using pygrib\"\"\"\n",
        "    try:\n",
        "        import pygrib\n",
        "        grbs = pygrib.open(file_path)\n",
        "        grb = grbs[1]\n",
        "        albedo = grb.values\n",
        "        lats, lons = grb.latlons()\n",
        "        grbs.close()\n",
        "        return albedo, lats, lons\n",
        "    except Exception as e:\n",
        "        return None, None, None\n",
        "\n",
        "def extract_subpolar_albedo(albedo, lats, lons):\n",
        "    \"\"\"Extract mean albedo for Subpolar Gyre (45-65°N, 60-10°W)\"\"\"\n",
        "    if albedo is None:\n",
        "        return np.nan\n",
        "\n",
        "    lat_mask = (lats >= 45) & (lats <= 65)\n",
        "    lon_mask = (lons >= -60) & (lons <= -10)\n",
        "    mask = lat_mask & lon_mask\n",
        "\n",
        "    if np.any(mask):\n",
        "        return np.mean(albedo[mask])\n",
        "    return np.nan\n",
        "\n",
        "# ============================================================\n",
        "# STEP 1: Download today's data\n",
        "# ============================================================\n",
        "\n",
        "print(\"\\n\" + \"=\"*70)\n",
        "print(\"STEP 1: DOWNLOADING TODAY'S DATA\")\n",
        "print(\"=\"*70)\n",
        "\n",
        "# Download today's data\n",
        "new_files = download_todays_albedo()\n",
        "print(f\"\\nDownloaded {len(new_files)} new files today\")\n",
        "\n",
        "# ============================================================\n",
        "# STEP 2: Load ALL files (existing + new)\n",
        "# ============================================================\n",
        "\n",
        "print(\"\\n\" + \"=\"*70)\n",
        "print(\"STEP 2: LOADING ALL ALB_RAD FILES\")\n",
        "print(\"=\"*70)\n",
        "\n",
        "# Path to data\n",
        "data_dir = Path(\"./alb_rad_data\")\n",
        "alb_files = sorted(data_dir.glob(\"*.grib2\"))\n",
        "\n",
        "print(f\"\\nFound {len(alb_files)} ALB_RAD files:\")\n",
        "\n",
        "# Extract metadata\n",
        "file_info = []\n",
        "for f in alb_files:\n",
        "    match = re.search(r'(\\d{10})', f.name)\n",
        "    if match:\n",
        "        timestamp = pd.to_datetime(match.group(1), format='%Y%m%d%H')\n",
        "        size_mb = f.stat().st_size / 1024 / 1024\n",
        "        file_info.append({\n",
        "            'timestamp': timestamp,\n",
        "            'file': f.name,\n",
        "            'size_mb': size_mb\n",
        "        })\n",
        "        print(f\"  {timestamp}: {f.name} ({size_mb:.2f} MB)\")\n",
        "\n",
        "df_files = pd.DataFrame(file_info)\n",
        "if len(df_files) > 0:\n",
        "    df_files = df_files.sort_values('timestamp')\n",
        "    print(f\"\\nDate range: {df_files['timestamp'].min()} to {df_files['timestamp'].max()}\")\n",
        "    print(f\"Unique dates: {df_files['timestamp'].dt.date.nunique()}\")\n",
        "\n",
        "# ============================================================\n",
        "# STEP 3: Extract albedo data\n",
        "# ============================================================\n",
        "\n",
        "print(\"\\n\" + \"=\"*70)\n",
        "print(\"STEP 3: EXTRACTING ALBEDO DATA\")\n",
        "print(\"=\"*70)\n",
        "\n",
        "timestamps = []\n",
        "albedo_values = []\n",
        "\n",
        "for f in alb_files:\n",
        "    match = re.search(r'(\\d{10})', f.name)\n",
        "    if not match:\n",
        "        continue\n",
        "\n",
        "    timestamp = pd.to_datetime(match.group(1), format='%Y%m%d%H')\n",
        "    timestamps.append(timestamp)\n",
        "\n",
        "    albedo, lats, lons = load_albedo_pygrib(f)\n",
        "    sp_albedo = extract_subpolar_albedo(albedo, lats, lons)\n",
        "    albedo_values.append(sp_albedo)\n",
        "\n",
        "    print(f\"{timestamp}: Subpolar Gyre Albedo = {sp_albedo:.4f}\")\n",
        "\n",
        "# ============================================================\n",
        "# STEP 4: Create time series\n",
        "# ============================================================\n",
        "\n",
        "df_albedo = pd.DataFrame({\n",
        "    'timestamp': timestamps,\n",
        "    'albedo': albedo_values\n",
        "})\n",
        "df_albedo = df_albedo.set_index('timestamp').sort_index()\n",
        "\n",
        "# Remove any NaN values (failed extractions)\n",
        "df_albedo = df_albedo.dropna()\n",
        "\n",
        "print(f\"\\n{'='*70}\")\n",
        "print(\"SUBPOLAR GYRE ALBEDO TIME SERIES\")\n",
        "print(f\"{'='*70}\")\n",
        "print(df_albedo)\n",
        "\n",
        "# ============================================================\n",
        "# STEP 5: Statistical Analysis\n",
        "# ============================================================\n",
        "\n",
        "if len(df_albedo) > 0:\n",
        "    print(f\"\\n{'='*70}\")\n",
        "    print(\"STATISTICAL ANALYSIS\")\n",
        "    print(f\"{'='*70}\")\n",
        "    print(f\"Number of observations: {len(df_albedo)}\")\n",
        "    print(f\"Mean albedo: {df_albedo['albedo'].mean():.4f}\")\n",
        "    print(f\"Std deviation: {df_albedo['albedo'].std():.4f}\")\n",
        "    print(f\"Min: {df_albedo['albedo'].min():.4f}\")\n",
        "    print(f\"Max: {df_albedo['albedo'].max():.4f}\")\n",
        "    print(f\"Range: {df_albedo['albedo'].max() - df_albedo['albedo'].min():.4f}\")\n",
        "\n",
        "    # Diurnal cycle\n",
        "    df_albedo['hour'] = df_albedo.index.hour\n",
        "    hourly_means = df_albedo.groupby('hour')['albedo'].mean()\n",
        "    print(f\"\\nDiurnal variation (by hour of day):\")\n",
        "    for hour, mean in hourly_means.items():\n",
        "        print(f\"  {hour:02d}:00 - {mean:.4f}\")\n",
        "\n",
        "# ============================================================\n",
        "# STEP 6: Save updated time series\n",
        "# ============================================================\n",
        "\n",
        "if len(df_albedo) > 0:\n",
        "    df_albedo.to_csv('albedo_timeseries_updated.csv')\n",
        "    print(f\"\\n✓ Saved: albedo_timeseries_updated.csv ({len(df_albedo)} points)\")\n",
        "\n",
        "# ============================================================\n",
        "# STEP 7: Visualization (only if data exists)\n",
        "# ============================================================\n",
        "\n",
        "if len(df_albedo) > 1:\n",
        "    fig, axes = plt.subplots(2, 2, figsize=(14, 10))\n",
        "\n",
        "    # Panel 1: Time series\n",
        "    ax = axes[0, 0]\n",
        "    ax.plot(df_albedo.index, df_albedo['albedo'], 'b-o', markersize=6, linewidth=1.5)\n",
        "    ax.fill_between(df_albedo.index,\n",
        "                    df_albedo['albedo'] - df_albedo['albedo'].std(),\n",
        "                    df_albedo['albedo'] + df_albedo['albedo'].std(),\n",
        "                    alpha=0.2)\n",
        "    ax.set_xlabel('Date/Time')\n",
        "    ax.set_ylabel('Albedo')\n",
        "    ax.set_title('Subpolar Gyre Albedo Time Series (Updated)')\n",
        "    ax.grid(True, alpha=0.3)\n",
        "\n",
        "    # Panel 2: Diurnal cycle\n",
        "    ax = axes[0, 1]\n",
        "    ax.bar(hourly_means.index, hourly_means.values, color='steelblue', alpha=0.7)\n",
        "    ax.set_xlabel('Hour of Day (UTC)')\n",
        "    ax.set_ylabel('Mean Albedo')\n",
        "    ax.set_title('Diurnal Cycle of Subpolar Gyre Albedo')\n",
        "    ax.grid(True, alpha=0.3, axis='y')\n",
        "\n",
        "    # Panel 3: Distribution\n",
        "    ax = axes[1, 0]\n",
        "    ax.hist(df_albedo['albedo'], bins='auto', color='steelblue', alpha=0.7, edgecolor='black')\n",
        "    ax.axvline(df_albedo['albedo'].mean(), color='r', linestyle='--',\n",
        "               label=f\"Mean: {df_albedo['albedo'].mean():.4f}\")\n",
        "    ax.set_xlabel('Albedo')\n",
        "    ax.set_ylabel('Frequency')\n",
        "    ax.set_title('Albedo Distribution')\n",
        "    ax.legend()\n",
        "    ax.grid(True, alpha=0.3, axis='y')\n",
        "\n",
        "    # Panel 4: Summary\n",
        "    ax = axes[1, 1]\n",
        "    ax.axis('off')\n",
        "\n",
        "    # FIXED: Properly handle unique dates\n",
        "    if len(df_albedo) > 0:\n",
        "        date_counts = df_albedo.index.date\n",
        "        unique_dates = len(set(date_counts))\n",
        "        min_date = df_albedo.index.min().date()\n",
        "        max_date = df_albedo.index.max().date()\n",
        "    else:\n",
        "        unique_dates = 0\n",
        "        min_date = \"N/A\"\n",
        "        max_date = \"N/A\"\n",
        "\n",
        "    summary_text = f\"\"\"\n",
        "UPDATED ALBEDO DATA SUMMARY\n",
        "{'='*35}\n",
        "\n",
        "Dataset Information:\n",
        "• Total files: {len(alb_files)}\n",
        "• Unique dates: {unique_dates}\n",
        "• Date range: {min_date} to {max_date}\n",
        "• Observations: {len(df_albedo)}\n",
        "\n",
        "Subpolar Gyre Albedo:\n",
        "• Mean: {df_albedo['albedo'].mean():.4f}\n",
